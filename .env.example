# Banco de dados PostgreSQL (Neon, Supabase, Railway, etc.)
# Exemplo Neon: postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# NextAuth — gere um segredo com: openssl rand -base64 32
NEXTAUTH_SECRET="seu-segredo-aqui"

# URL do sistema em produção (sem barra no final)
NEXTAUTH_URL="https://seu-sistema.vercel.app"
